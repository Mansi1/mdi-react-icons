{
  "name": "@mui-extra/icons",
  "version": "1.0.2",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "@mui-extra",
    "@mui-extra/icons",
    "icons",
    "mui/icons",
    "mdi icons",
    "material ui icons",
    "material icons",
    "mui icons"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mansi1/mdi-react-icons.git"
  },
  "license": "MIT",
  "author": "Michael Mannseicher",
  "bugs": {
    "url": "https://github.com/Mansi1/mdi-react-icons/issues"
  },
  "sideEffects": false,
  "main": "./index.js",
  "module": "./esm/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./esm/index.js",
      "require": "./index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./esm/*.js",
      "require": "./*.js"
    }
  },
  "peerDependencies": {
    "@mui/material": "^5.2.8",
    "react": "*"
  }
}
