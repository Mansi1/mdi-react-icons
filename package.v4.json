{
  "name": "@material-ui-extra/icons",
  "version": "1.1.4",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "@material-ui-extra",
    "@material-ui-extra/icons",
    "icons",
    "material-ui/icons",
    "mdi icons",
    "material ui icons",
    "material icons"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mansi1/mdi-react-icons.git"
  },
  "license": "MIT",
  "author": "Michael Mannseicher",
  "bugs": {
    "url": "https://github.com/Mansi1/mdi-react-icons/issues"
  },
  "sideEffects": false,
  "main": "./index.js",
  "module": "./esm/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./esm/index.js",
      "require": "./index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./esm/*.js",
      "require": "./*.js"
    }
  },
  "peerDependencies": {
    "@material-ui/core": "^4.0.0",
    "react": "*"
  }
}
